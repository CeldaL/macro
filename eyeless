-- Función para manejar el golpe normal

local function NormalHit()

    if hum.Health <= 0 or cooldown -- or isChargingStrong then return end

    then

        return

    end



    cooldown = true



    if firstPunchIgnored then

        firstPunchIgnored = false

        cooldown = false

        return

    end



    local animationSpeed = 0.7 -- Velocidad de la animación más lenta

    if not firstHitDone then

        -- Aquí podríamos intentar reproducir una animación diferente si existe para el primer golpe derecho

        punchAnim:Play(nil, nil, animationSpeed)

        firstHitDone = true

    else

        punchAnim:Play(nil, nil, animationSpeed)

    end



    events.Punch:FireServer(0.05, 0, combo)



    combo = combo + 1

    if combo > 5 then combo = 1 end



    task.delay(currentHitDelay, function()

        cooldown = false

    end)

end



