-- ✅ Super Fast Punch Script (sin bugs de input/UI)
local Players = game:GetService("Players")
local InputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local char = plr.Character or plr.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local root = char:WaitForChild("HumanoidRootPart")

local events = ReplicatedStorage:WaitForChild("Events")
local anims = ReplicatedStorage:WaitForChild("Animations")

local punchAnims = {}
for i = 1, 5 do
    if anims:FindFirstChild("combat" .. i) then
        table.insert(punchAnims, hum:LoadAnimation(anims["combat" .. i]))
    end
end

-- Variables de control
local punching = false
local combo = 1
local lastPunch = 0
local punchCooldown = 0.01

-- Asegura que energía y salud existan
_G.energy = _G.energy or 100
_G.lastAttack = _G.lastAttack or 0

local function CanPunch()
    return hum and hum.Health > 0 and _G.energy > 0 and (tick() - lastPunch >= punchCooldown)
end

local function Punch()
    if not CanPunch() then return end

    lastPunch = tick()
    _G.lastAttack = tick()

    local anim = punchAnims[combo]
    if anim then
        anim:Play(0.05, 1, 3)
        task.delay(0.01, function()
            anim:AdjustSpeed(15)
        end)
        task.delay(0.05, function()
            anim:Stop()
        end)
    end

    events.Punch:FireServer(0.01, punchCooldown, combo)
    _G.energy = math.max(_G.energy - 10, 0)

    combo = combo + 1
    if combo > #punchAnims then combo = 1 end
end

-- Ejecuta el golpeo en cada Heartbeat si se está presionando click
RunService.Heartbeat:Connect(function()
    if punching then
        Punch()
    end
end)

-- Control de input sin bloqueo de UI
InputService.InputBegan:Connect(function(input, processed)
    if not processed and input.UserInputType == Enum.UserInputType.MouseButton1 then
        punching = true
    end
end)

InputService.InputEnded:Connect(function(input, processed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        punching = false
    end
end)

-- Reiniciar todo si el personaje muere/reaparece
plr.CharacterAdded:Connect(function(newChar)
    char = newChar
    hum = char:WaitForChild("Humanoid")
    root = char:WaitForChild("HumanoidRootPart")

    punching = false
    combo = 1

    punchAnims = {}
    for i = 1, 5 do
        if anims:FindFirstChild("combat" .. i) then
            table.insert(punchAnims, hum:LoadAnimation(anims["combat" .. i]))
        end
    end
end)
