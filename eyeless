local tick_result1_2 = tick()
local punchSpeed = 3  -- Aceleración extrema del golpe
local comboSpeed = 2  -- Aceleración del combo aún mayor

local function Conditions()
    -- Simplificamos y optimizamos las condiciones
    return enabled and hum.Health > 0 and hum.WalkSpeed > 0 and _G.energy > 0
end

-- Reducimos el tiempo de espera entre clics a 0.05 segundos
local function StartPunch()
    local tick_result1_2 = tick()
    mouseDown = true
    while tick() - tick_result1_2 < 0.05 and mouseDown do  -- Reducción máxima
        Shared.Step()
    end
    local var18 = false
    if tick() - tick_result1_2 >= 0.05 then
        var18 = true
    end
    Punch(var18)
end

function Punch(arg1)
    local tick_result1 = tick()
    local combo = 1  -- Inicializamos el combo a 1
    
    if combo == 5 then
        combo = 0
    end
    
    if Conditions() then
        lastPunch = tick_result1
        _G.lastAttack = tick_result1
        nextPunch = tick_result1 + 5
        
        combo = combo + 1
        if combo > 5 then
            combo = 1
        end

        local punchAnim = punchAnims[combo]
        punchAnim:Play(0.1, 1, punchSpeed)  -- Animación más rápida
        local p = root.CFrame.p
        
        -- Detectar y golpear el objetivo más cercano
        local target = Shared.GetClosestActor(Shared.GetActorsInRange(p, Shared_GetCamDirection(), math.clamp(hum.WalkSpeed * comboSpeed, 20, 100), 360, char))
        if target then
            Shared.FaceTarget(root, target.HumanoidRootPart, 0.5, true)
            events.Punch:FireServer(math.max(0.3, hitDelays[combo]), hitDelays[combo], combo)
            _G.lastAction = math.max(tick_result1, _G.lastAction)
            _G.energy = math.max(_G.energy - 5 * 2, 0)  -- Reducción de energía más rápida
        end
        
        -- Aceleración del golpe (animación más rápida)
        punchAnim:AdjustSpeed(2.5)  -- Aceleramos aún más la animación
        wait(0.2)  -- Reduce la espera entre los golpes

        -- Vuelve a la velocidad original de la animación
        punchAnim:AdjustSpeed(0)
        wait(0.15)  -- Espera antes de detener la animación
        punchAnim:Stop(0.3, 1, 0)
    end
end

-- Configuración de Input (respuesta ultra rápida)
function InputBegan(arg1, arg2)
    if not arg2 then
        local UserInputType = arg1.UserInputType
        if UserInputType == Enum.UserInputType.MouseButton1 then
            StartPunch()  -- Aceleración extrema al iniciar el golpe
        end
    end
end

function InputEnded(arg1, arg2)
    if not arg2 and arg1.UserInputType == Enum.UserInputType.MouseButton1 then
        mouseDown = false  -- Detiene el golpe cuando se suelta el clic
    end
end

-- Conexión de eventos
InputService.InputBegan:connect(InputBegan)
InputService.InputEnded:connect(InputEnded)
